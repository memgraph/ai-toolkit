FROM python:3.12-slim

WORKDIR /app

# Install uv for fast dependency management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Copy dependency files first for layer caching
COPY pyproject.toml uv.lock ./

# Install dependencies (no dev deps, frozen lockfile)
RUN uv sync --frozen --no-dev --no-install-project

# Copy application source
COPY . .

# Install the project itself
RUN uv sync --frozen --no-dev

# Copy .env.example as reference; users supply real values at runtime
# via: docker build -f Dockerfile.local -t memgraph/structured2graph .
#      docker run -it --env-file .env memgraph/structured2graph
COPY .env.example /app/.env.example

ENTRYPOINT ["uv", "run", "main.py"]
