CREATE (:Industry {code: '5112', name: 'Stationery and Office Supplies', description: '5112 Stationery and Office SuppliesEstablishments primarily engaged in the wholesale distribution of stationery and office supplies, including computer and photocopy supplies, envelopes, typewriter paper, file cards and folders, pens, pencils, social stationery, and greeting cards.', examples: ["Albums (photo) and scrapbooks-wholesale", "Blankbooks-wholesale", "Business forms-wholesale", "Carbon paper-wholesale", "Commercial stationers (not printers)-wholesale", "Computer paper-wholesale", "Envelopes-wholesale", "File cards-wholesale", "File folders-wholesale", "Greeting cards-wholesale"]});
CREATE (:Industry {code: '5113', name: 'Industrial and Personal Service Paper', description: '5113 Industrial and Personal Service PaperEstablishments primarily engaged in the wholesale distribution of wrapping and other coarse paper, paperboard, and converted paper and related disposable plastics products, such as bags, boxes, dishes, eating utensils, napkins, and shipping supplies.', examples: ["Bags, paper and disposable plastics-wholesale", "Boxes, paperboard and disposable plastics-wholesale", "Cardboard and products-wholesale", "Closures, paper and disposable plastics-wholesale", "Containers, paper and disposable plastics-wholesale", "Corrugated and solid fiber boxes-wholesale", "Cups, paper and disposable plastics-wholesale", "Dishes, paper and disposable plastics-wholesale", "Eating utensils forks, knives, spoons-disposable plastics-wholesale", "Fiber cans and drums-wholesale"]});
